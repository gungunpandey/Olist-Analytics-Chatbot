# --- Agent ---
# llm      = OpenRouter tool-calling agent (needs OPENROUTER_API_KEY)
# fallback = rule-based keyword agent, no LLM at all
AGENT_MODE=llm

OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENROUTER_MODEL=anthropic/claude-sonnet-4.6

AGENT_TIMEOUT_SECONDS=60
TOOL_TIMEOUT_SECONDS=20

# --- Server ---
PORT=8000
